{
	"name": "isthereconsensus-monorepo",
	"type": "module",
	"version": "1.0.0",
	"private": true,
	"packageManager": "npm@11.12.0",
	"description": "Monorepo for isthereconsensus.org",
	"author": "Jacob Anderson",
	"license": "ISC",
	"workspaces": [
		"front-end",
		"back-end"
	],
	"scripts": {
		"build": "npm run -w front-end build && npm run -w back-end build",
		"dev": "npm run -w front-end dev",
		"server": "npm run -w back-end server",
		"server:once": "npm run -w back-end server:once",
		"serve": "npm run -w front-end serve",
		"lint-server": "npm run -w back-end lint-fix && npm run -w back-end server",
		"lint-serve": "npm run -w front-end lint-fix && npm run -w front-end serve",
		"lint": "npm run -w front-end lint && npm run -w back-end lint",
		"lint-fix": "npm run -w front-end lint-fix && npm run -w back-end lint-fix",
		"test": "npm run -w front-end test:unit && npm run -w back-end test",
		"typecheck": "npm run -w front-end typecheck && npm run -w back-end typecheck",
		"smoke:live": "node scripts/live-site-smoke.mjs",
		"smoke:ssr-assets": "node scripts/ssr-public-assets-smoke.mjs",
		"smoke:ssr-routes": "node scripts/ssr-route-rules-smoke.mjs",
		"clean": "sudo rm -rf node_modules dist package-lock.json **/node_modules **/dist **/package-lock.json **/.nuxt **/.output",
		"up": "node ./scripts/up.mjs",
		"a11y": "node scripts/a11y-smoke.mjs"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^8.2.0",
		"@typescript-eslint/eslint-plugin": "^8.59.0",
		"@typescript-eslint/parser": "^8.59.0",
		"@unocss/eslint-plugin": "^66.6.7",
		"axe-core": "^4.11.4",
		"esbuild": "0.28.1",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-vue": "^10.8.0",
		"globals": "^17.5.0",
		"h3": "1.15.11",
		"prettier": "^3.8.3",
		"puppeteer": "^24.43.1",
		"taze": "^19.11.0",
		"typescript": "^6.0.3"
	},
	"overrides": {
		"esbuild": "0.28.1",
		"vite": {
			"esbuild": "0.28.1"
		},
		"defu": "6.1.6",
		"anymatch": {
			"picomatch": "2.3.2"
		},
		"brace-expansion": "5.0.6",
		"micromatch": {
			"picomatch": "2.3.2"
		},
		"minimatch@10.2.4": {
			"brace-expansion": "5.0.6"
		},
		"minimatch@9.0.9": {
			"brace-expansion": "2.0.3"
		},
		"node-forge": "1.4.0",
		"path-to-regexp": "8.4.0",
		"picomatch": "4.0.4",
		"qs": "6.15.2",
		"readdir-glob": {
			"minimatch": "5.1.9"
		},
		"readdirp": {
			"picomatch": "2.3.2"
		},
		"serialize-javascript": "7.0.5",
		"srvx": "0.11.13",
		"@cypress/request": {
			"uuid": "14.0.0",
			"qs": "6.15.2"
		},
		"nitropack": "2.13.4",
		"simple-git": "3.36.0"
	},
	"dependencies": {
		"qs": "6.15.2"
	}
}
