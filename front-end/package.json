{
	"name": "front-end",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "rm -rf dist && nuxt build && node ./scripts/write-public-metadata.mjs && rm -rf dist && mkdir -p dist && rsync -a .output/public/ dist/",
		"dev": "nuxt dev",
		"generate": "nuxt generate",
		"prepare": "nuxt prepare",
		"preview": "node ./scripts/preview.mjs",
		"_serve": "PORT=${PORT:-3000} node ./scripts/preview.mjs --port ${PORT:-3000} -o",
		"serve": "nuxt dev --open --host",
		"start": "node .output/server/index.mjs",
		"lint": "eslint .",
		"lint-fix": "eslint . --fix",
		"typecheck": "nuxt typecheck",
		"test:unit": "node --test --import tsx test/*.test.ts",
		"up": "taze major -I"
	},
	"dependencies": {
		"@vueuse/core": "^14.2.1",
		"pinia": "^3.0.4",
		"vue": "^3.5.30"
	},
	"optionalDependencies": {
		"@esbuild/linux-arm64": "^0.28.1",
		"@esbuild/linux-x64": "^0.28.1",
		"@oxc-minify/binding-linux-arm64-gnu": "^0.124.0",
		"@oxc-minify/binding-linux-x64-gnu": "^0.124.0",
		"@oxc-parser/binding-linux-arm64-gnu": "^0.124.0",
		"@oxc-parser/binding-linux-x64-gnu": "^0.124.0",
		"@oxc-transform/binding-linux-arm64-gnu": "^0.124.0",
		"@oxc-transform/binding-linux-x64-gnu": "^0.124.0",
		"@rollup/rollup-linux-arm64-gnu": "4.55.1",
		"@rollup/rollup-linux-x64-gnu": "4.55.1"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^7.7.3",
		"@iconify-json/carbon": "^1.2.19",
		"@iconify-json/twemoji": "^1.2.5",
		"@nuxt/eslint": "^1.16.0",
		"@nuxtjs/color-mode": "^4.0.0",
		"@pinia/nuxt": "^0.11.3",
		"@unocss/eslint-config": "^66.6.7",
		"@unocss/nuxt": "^66.6.7",
		"@vitejs/plugin-vue": "^6.0.6",
		"@vueuse/nuxt": "^14.2.1",
		"eslint": "^10.1.0",
		"eslint-plugin-format": "^2.0.1",
		"nuxt": "^4.4.8",
		"terser": "^5.46.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.0",
		"unocss": "^66.6.7",
		"unplugin": "^3.0.0",
		"vite": "^8.0.16",
		"vue-tsc": "^3.2.6"
	},
	"overrides": {
		"@nuxt/devtools": "^3.2.4",
		"@nuxt/kit": "^4.4.2",
		"nuxt": "^4.4.2",
		"unplugin": "^3.0.0",
		"vite": "^8.0.7"
	}
}
