{
	"name": "front-end",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "rm -rf dist && nuxt build && rm -rf dist && mkdir -p dist && rsync -a .output/public/ dist/",
		"dev:pwa": "VITE_PLUGIN_PWA=true nuxt dev",
		"dev": "nuxt dev",
		"generate": "nuxt generate",
		"prepare": "nuxt prepare",
		"preview": "node ./scripts/preview.mjs",
		"_serve": "PORT=${PORT:-3000} node ./scripts/preview.mjs --port ${PORT:-3000} -o",
		"serve": "VITE_PLUGIN_PWA=true nuxt dev --open --host",
		"start": "node .output/server/index.mjs",
		"lint": "eslint .",
		"lint-fix": "eslint . --fix",
		"typecheck": "nuxt typecheck",
		"test:e2e": "cypress open",
		"test:unit": "node --test --import tsx test/*.test.ts",
		"up": "taze major -I"
	},
	"dependencies": {
		"@vueuse/core": "^14.2.1",
		"pinia": "^3.0.4",
		"vue": "^3.5.28"
	},
	"optionalDependencies": {
		"@esbuild/linux-arm64": "0.27.2",
		"@esbuild/linux-x64": "0.27.2",
		"@oxc-minify/binding-linux-arm64-gnu": "0.102.0",
		"@oxc-minify/binding-linux-x64-gnu": "0.106.0",
		"@oxc-parser/binding-linux-arm64-gnu": "0.108.0",
		"@oxc-parser/binding-linux-x64-gnu": "0.106.0",
		"@oxc-transform/binding-linux-arm64-gnu": "0.108.0",
		"@oxc-transform/binding-linux-x64-gnu": "0.107.0",
		"@rollup/rollup-linux-arm64-gnu": "4.55.1",
		"@rollup/rollup-linux-x64-gnu": "4.55.1"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^7.4.3",
		"@iconify-json/carbon": "^1.2.18",
		"@iconify-json/twemoji": "^1.2.5",
		"@nuxt/devtools": "^3.2.1",
		"@nuxt/eslint": "^1.15.1",
		"@nuxtjs/color-mode": "^4.0.0",
		"@pinia/nuxt": "^0.11.3",
		"@unocss/eslint-config": "^66.6.0",
		"@unocss/nuxt": "^66.6.0",
		"@vite-pwa/nuxt": "^1.1.1",
		"@vitejs/plugin-vue": "^6.0.4",
		"@vueuse/nuxt": "^14.2.1",
		"cypress": "^15.10.0",
		"eslint": "^9.39.3",
		"eslint-plugin-format": "^1.4.0",
		"nuxt": "^4.3.1",
		"terser": "^5.46.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"unocss": "^66.6.0",
		"unplugin": "^3.0.0",
		"vite": "^7.3.1",
		"vue-tsc": "^3.2.5"
	},
	"overrides": {
		"@nuxt/devtools": "^3.2.1",
		"@nuxt/kit": "^4.3.1",
		"nuxt": "^4.3.1",
		"unplugin": "^3.0.0",
		"vite": "^7.3.1"
	}
}
